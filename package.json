{
  "name": "chris-towles-blog",
  "version": "0.1.0",
  "private": true,
  "author": "Chris Towles<Chris.Towles@gmail.com>",
  "maintainers": [
    "Chris Towles<Chris.Towles@gmail.com>"
  ],
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @chris-towles/blog build",
    "build:container": "pnpm tsx scripts/build.ts test staging",
    "build:container:keep": "pnpm tsx scripts/build.ts test staging --keep",
    "kill-port": "bash -c '. .env 2>/dev/null; fuser -k ${UI_PORT:-3000}/tcp 2>/dev/null; fuser -k 8081/tcp 2>/dev/null; pkill -f \"v[i]te build --watch --config mcp-ui\" 2>/dev/null; exit 0'",
    "mcp:dev": "PORT=8081 pnpm --filter @chris-towles/mcp dev",
    "ui-bundle:build": "pnpm --filter @chris-towles/blog build:ui-bundle",
    "ui-bundle:watch": "pnpm --filter @chris-towles/blog build:ui-bundle:watch",
    "dev": "pnpm docker:up && pnpm db:migrate && pnpm kill-port && pnpm ui-bundle:build && (pnpm mcp:dev &) && (pnpm ui-bundle:watch &) && pnpm --filter @chris-towles/blog dev",
    "dev:no-remote": "pnpm docker:up && pnpm db:migrate && pnpm kill-port && pnpm ui-bundle:build && (pnpm mcp:dev &) && (pnpm ui-bundle:watch &) && pnpm --filter @chris-towles/blog dev:no-remote",
    "gcp:staging:init": "cd infra/terraform/environments && terraform init -backend-config=staging.backend.tfvars",
    "gcp:staging:plan": "cd infra/terraform/environments && terraform init -backend-config=staging.backend.tfvars -reconfigure && terraform plan -var-file=staging.tfvars -lock-timeout=5m",
    "gcp:staging:apply": "cd infra/terraform/environments && terraform init -backend-config=staging.backend.tfvars -reconfigure && terraform apply -auto-approve -var-file=staging.tfvars -lock-timeout=5m",
    "gcp:staging:deploy": "pnpm tsx scripts/build.ts deploy staging",
    "gcp:staging:destroy": "cd infra/terraform/environments && terraform init -backend-config=staging.backend.tfvars -reconfigure && terraform destroy -var-file=staging.tfvars -lock-timeout=5m",
    "gcp:prod:init": "cd infra/terraform/environments && terraform init -backend-config=prod.backend.tfvars",
    "gcp:prod:plan": "cd infra/terraform/environments && terraform init -backend-config=prod.backend.tfvars -reconfigure && terraform plan -var-file=prod.tfvars -lock-timeout=5m",
    "gcp:prod:apply": "cd infra/terraform/environments && terraform init -backend-config=prod.backend.tfvars -reconfigure && terraform apply -auto-approve -var-file=prod.tfvars -lock-timeout=5m",
    "gcp:prod:deploy": "pnpm tsx scripts/build.ts deploy prod",
    "gcp:staging:logs": "pnpm tsx scripts/logs.ts --environment=staging",
    "gcp:staging:off": "pnpm tsx scripts/power.ts off",
    "gcp:staging:on": "pnpm tsx scripts/power.ts on",
    "gcp:prod:logs": "pnpm tsx scripts/logs.ts --environment=production",
    "db:proxy": "pnpm tsx scripts/start-db-proxy.ts",
    "db:generate": "pnpm --filter @chris-towles/blog db:generate",
    "db:migrate": "pnpm --filter @chris-towles/blog db:migrate",
    "db:studio": "pnpm --filter @chris-towles/blog db:studio",
    "etl:aviation": "pnpm --filter @chris-towles/blog etl:aviation",
    "gen:card-portraits": "pnpm tsx scripts/generate-card-portraits.ts",
    "gen:cards": "pnpm --filter @chris-towles/blog gen:cards",
    "docker:up": "docker compose up -d --wait",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down --volumes --remove-orphans && pnpm clean",
    "slides": "pnpm --filter @chris-towles/slides dev",
    "slides:export": "pnpm --filter @chris-towles/slides export",
    "slides:upgrade": "pnpm --filter @chris-towles/slides slides:upgrade",
    "slides:no-brainer": "pnpm --filter @chris-towles/slides dev no-brainer-upgrade.slides.md",
    "lint": "oxlint --ignore-pattern '.claude/worktrees/**' .",
    "lint:fix": "oxlint --ignore-pattern '.claude/worktrees/**' --fix-dangerously .",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "typecheck": "pnpm --filter @chris-towles/blog typecheck",
    "test": "pnpm --filter @chris-towles/blog test",
    "test:integration": "pnpm --filter @chris-towles/blog test:integration",
    "test:e2e": "pnpm --filter @chris-towles/blog test:e2e",
    "eval:stories": "tsx packages/evals/run-eval.ts eval -c packages/evals/promptfooconfig.stories.yaml",
    "prepare": "simple-git-hooks",
    "mcp:inspect": "pnpm dlx @modelcontextprotocol/inspector",
    "deps:update": "pnpm dlx taze --interactive --recursive",
    "clean": "rm -rf node_modules packages/*/node_modules .nuxt .output .nitro dist packages/*/.nuxt packages/*/.output pnpm-lock.yaml"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1078.0",
    "@google/genai": "^2.10.0",
    "youtube-transcript": "^1.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "citty": "^0.2.2",
    "cli-table3": "^0.6.5",
    "consola": "^3.4.2",
    "dotenv": "^17.4.2",
    "find-up": "^8.0.0",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "playwright-chromium": "^1.61.1",
    "sharp": "^0.35.3",
    "simple-git-hooks": "^2.13.1",
    "strip-json-comments": "^5.0.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "zod": "^4.4.3",
    "zx": "^8.8.5"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged && pnpm format && pnpm typecheck"
  },
  "lint-staged": {
    "*.png": "pnpm tsx scripts/compress-images.ts",
    "*.{ts,tsx,mts,cts,js,cjs,mjs}": [
      "oxlint --fix"
    ],
    "*.{ts,tsx,mts,cts,js,cjs,mjs,json,css,html,vue}": [
      "oxfmt --write"
    ]
  },
  "packageManager": "pnpm@10.28.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@duckdb/node-bindings",
      "@parcel/watcher",
      "@playwright/browser-chromium",
      "@swc/core",
      "better-sqlite3",
      "esbuild",
      "playwright-chromium",
      "protobufjs",
      "sharp",
      "simple-git-hooks",
      "unrs-resolver",
      "vue-demi"
    ],
    "overrides": {
      "pg-pool": "3.7.1"
    },
    "packageExtensions": {
      "vue-router": {
        "peerDependencies": {
          "@vue/language-core": "*"
        }
      }
    }
  }
}
