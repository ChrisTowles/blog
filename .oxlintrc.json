{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "vue"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "nursery": "off"
  },
  "rules": {
    "no-underscore-dangle": "off"
  },
  "ignorePatterns": ["node_modules", ".nuxt", ".output", "dist", "*.d.ts"]
}
