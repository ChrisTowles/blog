# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# But track our per-environment tfvars (no secrets, just config)
!environments/staging.tfvars
!environments/prod.tfvars
!environments/staging.backend.tfvars
!environments/prod.backend.tfvars

# Ignore override files as they are usually used to override resources locally
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore lock files (commit these in real projects, but exclude for initial setup)
# .terraform.lock.hcl
