# Docker Compose isolation (required for worktree support)
UI_PORT=3000
DB_PORT=5432

# PostgreSQL Connection
# Local development (Docker Compose): Run `pnpm docker:up` from project root
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
# Production (GCP Cloud SQL): Use public IP connection
# DATABASE_URL=postgresql://blog_app:YOUR_PASSWORD@YOUR_GCP_SQL_PUBLIC_IP:5432/blog

# Password for nuxt-auth-utils (minimum 32 characters)
NUXT_SESSION_PASSWORD=
# Anthropic API Key
ANTHROPIC_API_KEY=

# Site URL (used for generating absolute URLs in search/chat results)
# Local dev uses request origin automatically; this is for the Agent SDK tools
# NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Analytics 4 Measurement ID (optional — analytics disabled if unset)
# NUXT_PUBLIC_GTAG_ID=G-XXXXXXXXXX

#### Github OAuth apps###
# https://github.com/settings/developers
# GitHub OAuth client ID
NUXT_OAUTH_GITHUB_CLIENT_ID=
# GitHub OAuth client secret
NUXT_OAUTH_GITHUB_CLIENT_SECRET=

#### Google OAuth ###
# https://console.cloud.google.com/apis/credentials
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=


# AWS Bedrock (for RAG embeddings/reranking)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# GCS media bucket (optional — falls back to data URIs for local dev)
# GCS_BUCKET_NAME=your-project-media

# MCP data bucket — private GCS bucket + HMAC credentials. Hosts aviation
# Parquet under the `aviation/` prefix (plus any future MCP tool datasets).
# The bucket is NOT shared. For local dev, set up your own GCP project:
#   1. Create a bucket:           gsutil mb gs://your-mcp-data-bucket
#   2. Create a service account:  gcloud iam service-accounts create mcp-data-dev
#   3. Grant read on the bucket:  gsutil iam ch \
#        serviceAccount:mcp-data-dev@PROJECT.iam.gserviceaccount.com:objectViewer \
#        gs://your-mcp-data-bucket
#   4. Generate HMAC keys:        gcloud storage hmac create \
#        mcp-data-dev@PROJECT.iam.gserviceaccount.com
#   5. Run the ETL into your bucket (writes to aviation/ prefix):
#        MCP_DATA_BUCKET=your-mcp-data-bucket pnpm etl:aviation
# Then paste the HMAC access_id and secret below. DuckDB httpfs uses the
# S3-compat API (KEY_ID/SECRET only — no ADC / OAuth support).
MCP_DATA_BUCKET=
GCS_HMAC_KEY_ID=
GCS_HMAC_SECRET=

### Braintrust API keys ###
BRAINTRUST_API_KEY=
BRAINTRUST_PROJECT_NAME=

# Nuxt OG Image signing secret — prevents arbitrary image generation
# Generate with: npx nuxt-og-image generate-secret
NUXT_OG_IMAGE_SECRET=

# OpenTelemetry / New Relic (free tier) — evlog OTLP drain (REQUIRED)
# Local dev sends to the same New Relic account as staging/prod; OTEL_SERVICE_NAME
# (or the dev's user) is what separates the streams. Get a license key from
# https://one.newrelic.com → API keys → INGEST - LICENSE.
# US datacenter:  https://otlp.nr-data.net
# EU datacenter:  https://otlp.eu01.nr-data.net
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.nr-data.net
OTEL_EXPORTER_OTLP_HEADERS=api-key=YOUR_NEW_RELIC_LICENSE_KEY
OTEL_SERVICE_NAME=blog-dev