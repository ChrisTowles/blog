{
  "name": "@chris-towles/blog",
  "version": "0.1.0",
  "private": true,
  "author": "Chris Towles<Chris.Towles@gmail.com>",
  "maintainers": [
    "Chris Towles<Chris.Towles@gmail.com>"
  ],
  "type": "module",
  "scripts": {
    "build": "pnpm run build:ui-bundle && nuxt build",
    "build:ui-bundle": "vite build --config mcp-ui/aviation-answer/vite.config.ts && vite build --config mcp-ui/echo/vite.config.ts",
    "build:ui-bundle:watch": "bash -c 'vite build --watch --config mcp-ui/aviation-answer/vite.config.ts & vite build --watch --config mcp-ui/echo/vite.config.ts & wait'",
    "dev": "docker compose up -d && nuxt dev --dotenv ../../.env",
    "dev:debug": "DEBUG=*:*:*,vite:*:*  nuxt dev --dotenv ../../.env",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "oxlint .",
    "typecheck": "nuxt typecheck",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test": "NODE_OPTIONS='--import ./vitest.preload.mjs' vitest",
    "test:integration": "NODE_OPTIONS='--import ./vitest.preload.mjs' vitest -c vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:ui-bundle:e2e": "playwright test --config=mcp-ui/aviation-answer/playwright.config.ts",
    "cleanup": "npx nuxi cleanup",
    "docker:up": "docker compose up -d",
    "docker:stop": "docker compose stop",
    "docker:reset": "docker compose down -v",
    "etl:aviation": "tsx scripts/etl-aviation.ts",
    "gen:cards": "tsx scripts/generate-card-decks.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.141",
    "@anthropic-ai/sdk": "^0.89.0",
    "@duckdb/node-api": "1.5.2-r.2",
    "@google-cloud/storage": "^7.21.0",
    "@iconify-json/simple-icons": "^1.2.88",
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nuxt/ui": "^4.9.0",
    "@nuxtjs/mdc": "^0.21.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "braintrust": "^1.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.44.7",
    "echarts": "^6.1.0",
    "evlog": "^2.19.2",
    "find-up": "^6.3.0",
    "mermaid": "^11.16.0",
    "nuxt": "^4.4.8",
    "nuxt-auth-utils": "^0.5.29",
    "nuxt-og-image": "^6.7.0",
    "pg": "^8.22.0",
    "pixi.js": "^8.19.0",
    "postgres": "^3.4.9",
    "shiki": "2.3.1",
    "shiki-stream": "^0.1.5",
    "tailwindcss": "^4.3.2",
    "ts-fsrs": "^5.4.1",
    "ufo": "^1.6.4",
    "vue-echarts": "^8.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/heroicons-outline": "^1.2.1",
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/lucide": "^1.2.115",
    "@iconify-json/simple-icons": "^1.2.64",
    "@nuxt/content": "^3.14.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.2.5",
    "@nuxt/image": "^2.0.0",
    "@nuxt/test-utils": "^4.0.3",
    "@nuxtjs/sitemap": "^8.2.2",
    "@playwright/test": "^1.61.1",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^24.13.2",
    "@vue/language-core": "^3.3.6",
    "@vue/test-utils": "^2.4.11",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "baseline-browser-mapping": "^2.10.40",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "happy-dom": "^20.10.6",
    "nuxt-gtag": "^4.1.0",
    "playwright-core": "^1.61.1",
    "rollup": "^4.62.2",
    "typescript": "^5.9.3",
    "vite": "^8.1.2",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.6"
  }
}
